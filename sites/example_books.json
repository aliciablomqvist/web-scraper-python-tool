{
  "key": "example_books",
  "name": "Books to Scrape (körbart exempel/mall)",
  "base_url": "http://books.toscrape.com/catalogue/page-1.html",
  "link_selector": "article.product_pod h3 a",
  "extractor": "generic",
  "pagination": {
    "type": "url_pattern",
