{
  "key": "nomads",
  "name": "Nomads HRC Filmkatalog",
  "base_url": "https://nomadshrc.org/catalogue/public/",
  "link_selector": "a[href*='/catalogue/public/films/']",
  "extractor": "nomads",
  "fieldnames": [
    "Name of Documentary", "Director", "Language", "Subtitles",
    "Published year", "Type", "Link to Documentary", "Topic", "Source URL"
  ],
  "pagination": {
    "type": "next_button",
    "button_texts": ["Next"],
    "max_pages": 40,
    "click_wait_seconds": 1.8
  },
  "render_js": false,
  "request_delay_range": [2, 5],
  "title_field": "Name of Documentary"
}
