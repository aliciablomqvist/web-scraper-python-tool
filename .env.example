# Kopiera denna fil till ".env" och fyll i de värden ni faktiskt vill använda.
# ".env" är gitignorad och committas aldrig.

# --- Supabase (valfritt) ---
# Om dessa lämnas tomma sparas data bara lokalt i SQLite (nomads.db).
# Skapa ett gratis projekt på https://supabase.com, hämta URL + "anon"/"service_role"-nyckel
# under Project Settings -> API.
SUPABASE_URL=
SUPABASE_KEY=

# --- Discord-notiser (valfritt) ---
# Skapa en webhook i er Discord-server: Serverinställningar -> Integrationer -> Webhooks.
# Lämnas den tom skickas inga notiser.
DISCORD_WEBHOOK_URL=

# --- Notiser: filtrera på nyckelord (valfritt) ---
# Kommaseparerad lista. Matchar mot Topic/Type/Name i nya rader.
# Lämna tom för att notifiera om ALLA nya rader.
NOTIFY_KEYWORDS=
